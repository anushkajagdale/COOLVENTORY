PORT=3000

# MySQL/Database Configuration (for Render/Railway services)
# Use MYSQL* variables for Railway/Render MySQL service
MYSQLHOST=localhost
MYSQLUSER=root
MYSQLPASSWORD=root
MYSQLDATABASE=coolventory
MYSQLPORT=3306

# Alternative variable names (DB_*)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_NAME=coolventory
DB_PORT=3306
DB_CONNECTION_LIMIT=10

NODE_ENV=development
